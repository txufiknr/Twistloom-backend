# Local development environment variables
# Copy this file to .env.local and fill in your values
PORT=3000

# NextAuth v5 Configuration (Required for cookie-based authentication)
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Frontend URL (Required for CORS with credentials)
# Local development: http://localhost:3000
# Production: https://twistloom-web.vercel.app
FRONTEND_URL=http://localhost:3001

# Auth URL (Required for NextAuth cookie configuration)
# Should match your frontend domain exactly
AUTH_URL=http://localhost:3001

# Auth Rate Limiting (Optional)
# Controls IP-based rate limiting for credential verification endpoints
# AUTH_RATE_LIMIT_MAX_ATTEMPTS: Maximum login attempts per window (default: 5)
# AUTH_RATE_LIMIT_WINDOW_MS: Time window in milliseconds (default: 60000 = 1 minute)
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Get from: https://github.com/settings/tokens
GITHUB_API_KEY=github_api_key_here

# Get from: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=gemini_api_key_here

# Get from: https://console.mistral.ai/home?profile_dialog=api-keys
MISTRAL_API_KEY=mistral_api_key_here

# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=cohere_api_key_here

# Get from: https://cloud.cerebras.ai/platform/org_2ypxv2rc6j554f4f22pntket/apikeys
CEREBRAS_API_KEY=cerebras_api_key_here

# Get from: https://console.groq.com/keys
GROQ_API_KEY=groq_api_key_here

# Get from: https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=nvidia_api_key_here

# Get from: https://console.neon.tech/app/projects/broad-dust-07944744?database=neondb
# Example: DATABASE_URL=postgresql://user:password@host:port/database
DATABASE_URL=postgresql://primary...
DATABASE_READ_URL=postgres://replica...
DATABASE_LOGGING=true

# Get from: https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_API_KEY_PUBLIC=imagekit_api_key_public_here
IMAGEKIT_API_KEY_PRIVATE=imagekit_api_key_private_here
IMAGEKIT_URL_ENDPOINT=imagekit_url_endpoint_here

# Get from: https://upstash.com → Create a free Redis database
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required for Vercel API
# Set in: https://vercel.com/txufiknrs-projects/twistloom-backend/settings/environment-variables
# - NODE_ENV=production	       # Enables prod guards, disables debug logs
# - DATABASE_URL	           # Primary Neon DB (read/write)
# - DATABASE_READ_URL	       # Neon read replica
# - UPSTASH_REDIS_REST_URL	   # Rate limiting
# - UPSTASH_REDIS_REST_TOKEN   # Rate limiting
# - GEMINI_API_KEY	           # Story writing
# - GITHUB_API_KEY	           # Story writing
# - MISTRAL_API_KEY	           # Story writing
# - COHERE_API_KEY	           # Story writing
# - CEREBRAS_API_KEY	       # Story writing
# - GROQ_API_KEY	           # Story writing
# - NVIDIA_API_KEY	           # Story writing
# - IMAGEKIT_API_KEY_PRIVATE   # Image storage

# Required for GitHub Actions
# Set in: https://github.com/txufiknr/MuslimDigest-backend/settings/environments/11743441061/edit
# - DATABASE_URL	           # Primary Neon DB (read/write)
# - DATABASE_READ_URL	       # Read cron queue table
# - IMAGEKIT_API_KEY_PRIVATE   # Image deletion cron

# These should never go to production:
# - DATABASE_LOGGING=true
# - PORT=3000

# Admin
# get from: pnpm db:reset
DEFAULT_USER_ID=default_user_id