# -----------------------------------------------------
# 📦 Package management
# -----------------------------------------------------
# Improves compatibility on Windows (no deep symlinks)
node-linker=hoisted

# Don't hoist everything (reduces node_modules bloat)
shamefully-hoist=false

# Enforce peer dependency correctness (prevents silent mismatches)
strict-peer-dependencies=true

# Always verify integrity of packages (avoid corrupted cache)
verify-store-integrity=true

# -----------------------------------------------------
# 🧩 Install behavior
# -----------------------------------------------------
# Auto-approve common build tools
allowed-build-scripts=wordpos,esbuild

# Ensure installs use the lockfile (for CI & team consistency)
prefer-frozen-lockfile=true

# Automatically install missing peer deps
auto-install-peers=true

# Prefer offline cache (saves disk space)
prefer-offline=true

# No background server, direct store access
use-store-server=false